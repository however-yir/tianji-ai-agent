COMPOSE_PROJECT_NAME=tianji-ai-agent

# Frontend / backend ports
AIGC_FRONTEND_PORT=5173
AIGC_BACKEND_PORT=8094

# Backend runtime
AIGC_BACKEND_PROFILE=dev-demo
AIGC_BACKEND_JAVA_OPTS=

# Demo profile defaults
AIGC_DEMO_USER_ID=10001
AIGC_DEMO_TOKEN=dev-demo-token
AIGC_DEMO_STREAM_DELAY_MS=35

# MySQL
AIGC_MYSQL_PORT=3306
AIGC_MYSQL_ROOT_PASSWORD=root
AIGC_MYSQL_DATABASE=tj_aigc
AIGC_MYSQL_USERNAME=tianji
AIGC_MYSQL_PASSWORD=tianji123

# Redis
AIGC_REDIS_PORT=6379
AIGC_REDIS_PASSWORD=
AIGC_REDIS_DATABASE=0

# Optional infrastructure
AIGC_NACOS_PORT=8848
AIGC_ES_PORT=9200

# Optional model settings when you later switch away from dev-demo
OPENAI_API_KEY=replace_me
BASE_URL=https://api.openai.com
MODEL_NAME=gpt-4o-mini
MCP_SERVER_URL=http://127.0.0.1:8081
ELASTICSEARCH_URL=http://127.0.0.1:9200
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
